# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# oz-monitor — Environment Config
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Convex deployment URL (health check endpoint)
CONVEX_URL=http://127.0.0.1:3210

# PostgreSQL connection details (TCP ping)
PG_HOST=127.0.0.1
PG_PORT=5432

# Docker service name for Convex backend (from docker-compose.yml)
DOCKER_BACKEND_SERVICE=backend

# Project root directory (where docker-compose.yml lives)
# Defaults to parent of oz-monitor/ if not set
# PROJECT_ROOT=C:\Users\Thilak\Desktop\projects\OrderZap\v2\OZ-backend

# Health check interval in milliseconds (default: 10000 = 10s)
CHECK_INTERVAL=10000
# Optional overrides for aggressive monitoring:
CHECK_INTERVAL=1000
MAX_RETRIES=2
RETRY_DELAY=2000
